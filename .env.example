# Server Configurations
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Database Configurations
DATABASE_URL=sqlite:///./sql_app.db

# Storage Configurations
UPLOAD_DIR=backend/uploads
OUTPUT_DIR=backend/outputs
TEMP_DIR=backend/temp

# Security Configurations (Future)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Audio Extraction Configurations
FFMPEG_PATH=ffmpeg
AUDIO_FOLDER=backend/temp/audio
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Faster-Whisper Configurations
WHISPER_MODEL=small
DEVICE=cpu
COMPUTE_TYPE=int8

# WhisperX Alignment Configurations
ALIGNMENT_DEVICE=cpu
ALIGNMENT_BATCH_SIZE=16

# Subtitle Generation Configurations
MAX_WORDS_PER_LINE=5
MAX_LINES=2
READING_SPEED=18
DEFAULT_SUBTITLE_FORMAT=srt

# Caption Style Engine Configurations
DEFAULT_STYLE=default
DEFAULT_FONT=Arial
DEFAULT_FONT_SIZE=24

# Caption Animation Engine Configurations
DEFAULT_ANIMATION=word_highlight
DEFAULT_DURATION=0.3
DEFAULT_HIGHLIGHT_COLOR=#FFFF00
